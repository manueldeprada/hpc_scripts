# ============================================================================
#  hpc_scripts managed zsh config
#  https://github.com/manueldeprada/hpc_scripts
#
#  This file is cloud-synced across all your machines and is overwritten on
#  auto-update, so do NOT edit it for one machine. It is sourced near the top
#  of ~/.zshrc; put machine-specific config below that source line in ~/.zshrc
#  (that file is never synced), which is also where tool installers append.
# ============================================================================

: ${HPC_ZSH_DIR:="$HOME/.hpc_scripts"}
# Public HTTPS URL, always used for updates so a machine without an SSH key
# can never hang on a key/credential prompt (even if origin is an SSH remote).
: ${HPC_ZSH_REMOTE:="https://github.com/manueldeprada/hpc_scripts.git"}

_hpc_zsh_stamp="${XDG_CACHE_HOME:-$HOME/.cache}/hpc_zsh_lastupdate"

# Pull the latest config over HTTPS, with all interactive prompts disabled so
# it fails fast instead of blocking the shell if auth is ever needed.
_hpc_zsh_pull() {
  [[ -d "$HPC_ZSH_DIR/.git" ]] || return 1
  GIT_TERMINAL_PROMPT=0 GIT_SSH_COMMAND='ssh -oBatchMode=yes' \
    git -C "$HPC_ZSH_DIR" pull --ff-only "$@" "$HPC_ZSH_REMOTE"
}

# ---------------------------------------------------------------------------
# Auto-update: pull the latest config from GitHub, at most once a day, in the
# background so it never blocks or slows down shell startup. Changes apply on
# the next shell launch. Run `zsync` to force an update now.
# ---------------------------------------------------------------------------
_hpc_zsh_autoupdate() {
  [[ -n "${HPC_ZSH_NO_UPDATE:-}" ]] && return   # disabled via install --no-update
  [[ -d "$HPC_ZSH_DIR/.git" ]] || return
  local now last=0
  now=$(date +%s)
  [[ -f "$_hpc_zsh_stamp" ]] && last=$(cat "$_hpc_zsh_stamp" 2>/dev/null || echo 0)
  (( now - last < 86400 )) && return          # 86400s = 24h
  mkdir -p "${_hpc_zsh_stamp:h}"
  print -r -- "$now" > "$_hpc_zsh_stamp"
  ( _hpc_zsh_pull --quiet >/dev/null 2>&1 & )
}
_hpc_zsh_autoupdate

# Force an update right now, then reload the shell.
zsync() {
  echo "hpc_scripts: pulling latest zsh config over HTTPS..."
  _hpc_zsh_pull || { echo "hpc_scripts: update failed (offline or local changes?)"; return 1; }
  mkdir -p "${_hpc_zsh_stamp:h}"; print -r -- "$(date +%s)" > "$_hpc_zsh_stamp"
  exec zsh
}

# ---------------------------------------------------------------------------
# Sync dotfiles from the repo (canonical copy). If a machine's copy was changed
# locally, warn loudly instead of overwriting, so a local change is never lost.
# Disable per file with install flags (--no-claude-sync, --no-tmux-sync).
# ---------------------------------------------------------------------------
_hpc_sha() {
  local o
  if (( ${+commands[sha256sum]} )); then o=$(sha256sum "$1" 2>/dev/null)
  elif (( ${+commands[shasum]} )); then o=$(shasum -a 256 "$1" 2>/dev/null)
  else o=$(cksum "$1" 2>/dev/null); fi
  print -r -- "${o%% *}"
}

# _hpc_sync_file <repo-relative-path> <dest> <cache-key>
_hpc_sync_file() {
  local repo="$HPC_ZSH_DIR/$1" dest="$2"
  local basef="${XDG_CACHE_HOME:-$HOME/.cache}/hpc_${3}_base"
  [[ -f "$repo" ]] || return
  local rh dh bh
  rh=$(_hpc_sha "$repo")
  [[ -f "$dest" ]] && dh=$(_hpc_sha "$dest") || dh=""
  [[ -f "$basef" ]] && bh=$(<"$basef") || bh=""

  if [[ -z "$dh" ]]; then                      # no local copy yet: install it
    mkdir -p "${dest:h}"; cp "$repo" "$dest"; print -r -- "$rh" >| "$basef"; return
  fi
  if [[ "$dh" == "$rh" ]]; then                # already in sync
    print -r -- "$rh" >| "$basef"; return
  fi
  if [[ "$dh" == "$bh" ]]; then                # local untouched, repo moved on
    cp "$repo" "$dest"; print -r -- "$rh" >| "$basef"; return
  fi
  # Local diverged from both repo and last-synced baseline: warn, do not touch.
  print -P "%B%F{red}"
  print "  =================================================================="
  print "   WARNING: $dest was changed on THIS machine and differs from the"
  print "   synced (repo) version."
  print ""
  print "     discard it:  rm $dest   (restored from sync on the next shell)"
  print "     keep it:     cp $dest $repo   then commit and push"
  print "  =================================================================="
  print -P "%f%b"
}

# ~/.claude/CLAUDE.md (only where Claude Code is set up)
[[ -n "${HPC_ZSH_NO_CLAUDE_SYNC:-}" ]] || [[ ! -d "$HOME/.claude" ]] ||
  _hpc_sync_file "claude/CLAUDE.md" "$HOME/.claude/CLAUDE.md" claudemd

# ~/.tmux.conf
[[ -n "${HPC_ZSH_NO_TMUX_SYNC:-}" ]] ||
  _hpc_sync_file "tmux/tmux.conf" "$HOME/.tmux.conf" tmuxconf

# ---------------------------------------------------------------------------
# PATH: user-local bin (uv, pipx, ...) + the repo's synced scripts (rtmux, duh).
# --no-scripts (HPC_ZSH_NO_SCRIPTS) leaves the repo bin/ off PATH.
# ---------------------------------------------------------------------------
if [[ -n "${HPC_ZSH_NO_SCRIPTS:-}" ]]; then
  export PATH="$HOME/.local/bin:$PATH"
else
  export PATH="$HOME/.local/bin:$HPC_ZSH_DIR/zsh/bin:$PATH"
fi

# Some clusters load zsh from a module directory that is not on $PATH, which
# breaks tools that shell out to `zsh` (antidote and friends). If zsh is not on
# PATH, add the directory of the running zsh binary (Linux: /proc/self/exe).
if (( ! ${+commands[zsh]} )) && [[ -e /proc/self/exe ]]; then
  _hpc_zdir=${${:-/proc/self/exe}:A:h}
  if [[ -x "$_hpc_zdir/zsh" ]]; then
    path=("$_hpc_zdir" $path)
    rehash
  fi
  unset _hpc_zdir
fi

# ---------------------------------------------------------------------------
# antidote plugin manager
# ---------------------------------------------------------------------------
[[ -e ${ZDOTDIR:-$HOME}/.antidote ]] ||
  git clone --depth=1 https://github.com/mattmc3/antidote.git ${ZDOTDIR:-$HOME}/.antidote

autoload -Uz compinit && compinit

source ${ZDOTDIR:-$HOME}/.antidote/antidote.zsh

# Drop a broken/empty antidote cache (e.g. left by an earlier failed run) so it
# is regenerated instead of sourced empty, which silently loads no plugins.
[[ -f "$HPC_ZSH_DIR/zsh/.zsh_plugins.zsh" && ! -s "$HPC_ZSH_DIR/zsh/.zsh_plugins.zsh" ]] &&
  rm -f "$HPC_ZSH_DIR/zsh/.zsh_plugins.zsh"

antidote load "$HPC_ZSH_DIR/zsh/.zsh_plugins.txt"

# ---------------------------------------------------------------------------
# starship prompt (replaces powerlevel10k). Config is synced from the repo.
# Install: curl -sS https://starship.rs/install.sh | sh
# ---------------------------------------------------------------------------
if command -v starship >/dev/null 2>&1; then
  export STARSHIP_CONFIG="$HPC_ZSH_DIR/zsh/starship.toml"
  eval "$(starship init zsh)"
fi

# ---------------------------------------------------------------------------
# Keybindings
# ---------------------------------------------------------------------------
bindkey '^[[1;3C' forward-word     # Alt/Option + Right  -> forward one word
bindkey '^[[1;3D' backward-word    # Alt/Option + Left   -> backward one word

# Machine-specific config is NOT sourced here. It lives below the `source` line
# in ~/.zshrc, which runs right after this file returns.
